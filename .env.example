# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=a-long-random-secret-used-to-sign-tokens

# ── Hugging Face (model download) ─────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
HF_DATASET_REPO=your-org/your-dataset-repo

# ── Model ─────────────────────────────────────────────────────────────────────
ONNX_MODEL_PATH=/opt/render/project/src/best_combined.onnx
CONFIDENCE_THRESHOLD=0.45
IOU_THRESHOLD=0.45
MAX_IMAGE_SIZE_MB=5

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
TRUSTED_HOST=your-api.onrender.com
DEBUG=false
APP_VERSION=1.0.0

# ── Sentry ────────────────────────────────────────────────────────────────────
# Get your DSN from: https://sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
SENTRY_ENV=production
